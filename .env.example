# ─────────────────────────────────────────
# Steam Deck Alert — Environment Config
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# How often to poll Steam (in seconds). Don't go below 30.
POLL_INTERVAL_SECONDS=60

# ── Notification method ──────────────────
# Options: "webhook", "firebase", or "both"
NOTIFY_METHOD=webhook

# ── Discord / Slack webhook (easiest for testing) ──
# Create a Discord server → Edit channel → Integrations → New Webhook → Copy URL
# Or use https://ntfy.sh for dead-simple push notifications (no account needed)
WEBHOOK_URL=https://ntfy.sh/YOUR_UNIQUE_TOPIC_HERE

# ── Firebase (for the mobile app) ────────
# After setting up Firebase project, download serviceAccountKey.json
# and set this path
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Firebase project ID (found in Firebase Console → Project Settings)
FIREBASE_PROJECT_ID=your-firebase-project-id
